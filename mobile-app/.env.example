# Copy this file to .env and set your machine's LAN IP before running the app on a physical device.
# Example:
# EXPO_PUBLIC_API_URL=http://192.168.1.42:5000/api

EXPO_PUBLIC_API_URL=http://YOUR_IP:5000/api

# Notes:
# - Do NOT commit your actual .env with IPs to version control.
# - On Android devices using Expo Go, use your machine's LAN IP (not localhost).